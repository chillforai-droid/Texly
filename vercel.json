{
  "routes": [
    { "src": "^/api/(.*)", "dest": "/api/$1" },
    { "src": "^/sitemap.xml$", "dest": "/api/sitemap" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/auto-index",
      "schedule": "*/30 * * * *"
    }
  ]
}
